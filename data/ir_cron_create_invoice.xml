<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data noupdate="0">
       <record id="po_delay_check" model="ir.cron">
           <field name="name">PO Delay Check</field>
           <field name="model_id" ref="po_delay.model_purchase_order"/>
           <field name="state">code</field>
           <field name="code">model.po_delay()</field>
           <field name="user_id" ref="base.user_root"/>
           <field name='interval_number'>1</field>
           <field name='interval_type'>days</field>
           <field name="nextcall"
                  eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 12:00:00')"/>
           <field name="priority">1</field>
       </record>
   </data>
</odoo>
